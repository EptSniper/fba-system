# ============================================================
# scout_pro configuration — copy to ".env" and fill in.
#   cp .env.example .env
# Defaults run the whole system on SQLite + scikit-learn with NO external infra.
# ============================================================

# ---- Data layer ----
# Postgres in production; leave unset to use a local SQLite file.
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/fba
DATABASE_URL=sqlite:///scout_pro.db
DATA_LAKE_DIR=data_lake
MODEL_REGISTRY_DIR=model_registry

# ---- Credentials (only Keepa + Discord are needed to run) ----
KEEPA_KEY=
KEEPA_DOMAIN=US
DISCORD_WEBHOOK_URL=

# ---- Owned-account truth (optional; connectors are stubs until you wire them) ----
SP_API_REFRESH_TOKEN=
SP_API_CLIENT_ID=
SP_API_CLIENT_SECRET=
ADS_API_REFRESH_TOKEN=

# ---- Discovery criteria ----
PRICE_MIN=15
PRICE_MAX=50
MIN_MONTHLY_SALES=200
MAX_REVIEWS=500
MAX_RATING=4.3
MAX_WEIGHT_LB=1.0
MAX_OFFERS=15
CANDIDATE_LIMIT=200

# ---- Hard gates (reject regardless of model score) ----
GATE_MARGIN_FLOOR=0.15
GATE_MAX_OFFERS=25
GATE_MAX_LEAD_TIME=60
GATE_MAX_WEIGHT_LB=5.0
GATE_FORBIDDEN_CATEGORIES=lithium,battery,hazmat,flammable,aerosol,knife,weapon,supplement,cbd,medical device,grocery

# ---- Labels (weak proxy + strong realized) ----
LABEL_HORIZONS=30,90,180
PRIMARY_HORIZON=90
STRONG_MIN_MARGIN=0.20
STRONG_MIN_UNITS=200
STRONG_MIN_FO_SHARE=0.7
STRONG_MAX_RETURN_RATE=0.10
WEAK_SUCCESS_THRESHOLD=0.60

# ---- Margin assumptions (2026 fee schedule) ----
REFERRAL_RATE=0.15
FUEL_SURCHARGE=0.035
COGS_FRACTION=0.30
PPC_FRACTION=0.10
TARGET_NET_MARGIN=0.25

# ---- Model + serving ----
MODEL_BLEND_WEIGHT=0.5
MIN_LABELS_TO_TRAIN=40
ALERT_PROBABILITY=0.70
UNCERTAINTY_LOW=0.45
UNCERTAINTY_HIGH=0.65
TOP_N=5
PROMOTION_MIN_GAIN=0.02
DRIFT_PSI_THRESHOLD=0.2
