# control-center configuration — copy to ".env.local" and fill in.
#   cp .env.example .env.local
# Everything below is OPTIONAL: the dashboard degrades honestly (features show
# "not connected" / honest empty states) when unset. Nothing here is required to run
# `npm run dev` against the local learning-hub/ JSON files.

# --- Supabase business tables (CC1 — Review Queue, Runs health, live Leads/Deals) -------
# SERVER-ONLY. Read via plain PostgREST REST calls in lib/supabase-server.ts (no SDK
# dependency) — this key must NEVER be imported by a "use client" component or returned in
# any API response body. Same project as scout/.env's SUPABASE_URL/SUPABASE_SERVICE_KEY.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Operator auth (middleware.ts) -------------------------------------------------------
# REQUIRED before deploying with the Supabase vars above: the /api/ops/* routes write real
# decisions with the service-role key, so the whole app sits behind HTTP Basic auth when
# these are set. Unset locally = open on localhost (dev convenience). A deployed instance
# (VERCEL env present) that has Supabase configured but NO auth refuses to serve at all.
BASIC_AUTH_USER=
BASIC_AUTH_PASS=

# --- Anthropic API (CC2+ — /proposals page's "Approve" drafting) -------------------------
# SERVER-ONLY, used by lib/anthropic-draft.ts to draft a proposed ai-brain.json edit the
# moment you approve a brain-proposals.md finding (a human still confirms the draft before
# anything is written). Same key as scout/.env's ANTHROPIC_API_KEY (HUMAN_TODO.md item #1) —
# without it, "Approve" honestly records "approved — no draft" instead of failing silently.
ANTHROPIC_API_KEY=
# ANTHROPIC_DRAFT_MODEL=claude-sonnet-5

# --- Optional: override the Python binary used to shell out to knowledge-rag/ask.py -----
# PYTHON_BIN=python
