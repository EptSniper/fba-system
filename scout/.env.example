# ============================================================
# Product Scout configuration. Copy this file to ".env" and fill it in.
#   cp .env.example .env
# Nothing here is committed by you to source control — keep .env private.
# ============================================================

# ---- REQUIRED credentials ----
# Paid Keepa subscription key (Premium ~$19+/mo unlocks sales data, Product
# Finder, and API access). Get it at: https://keepa.com/#!api
KEEPA_KEY=

# ---- Discord multi-channel routing (discord_router.py) ----
# One webhook per notification stream (no bot token needed):
# Server Settings -> Integrations -> Webhooks -> New Webhook -> Copy URL, per channel.
# Any stream left blank falls back to DISCORD_WEBHOOK_FALLBACK; if that's blank too, the
# router logs an honest skip rather than failing the run.
DISCORD_WEBHOOK_DAILY_DIGEST=
DISCORD_WEBHOOK_SCOUT_PICKS=
DISCORD_WEBHOOK_RETAIL_DEALS=
DISCORD_WEBHOOK_REVIEW_QUEUE=
DISCORD_WEBHOOK_BRAIN_PROPOSALS=
DISCORD_WEBHOOK_SYSTEM_HEALTH=
DISCORD_WEBHOOK_OUTCOMES=
DISCORD_WEBHOOK_FALLBACK=
# Below this many Keepa tokens left, run_daily.py posts a dedicated system_health warning.
LOW_TOKEN_WARNING_THRESHOLD=1000
# Legacy single-channel webhook, kept only for discord_notify.py's `webhook_url` override
# argument (manual/direct posting) — NOT read by discord_router.py's stream resolution.
DISCORD_WEBHOOK_URL=

# healthchecks.io (free) dead-man's-switch: run_daily.py pings this on success, .../fail on
# failure, so a machine that never woke up is still detected. Optional — honest no-op if unset.
HEALTHCHECK_URL=

# Anthropic API key (scout/analyst.py's LLM second-opinion pass + scout/reflect.py's weekly
# brand-memory reflection, both Scout Agent Build Plan; shared with Deal Finder Prompt D2's
# matcher). Absent -> both features honestly no-op.
ANTHROPIC_API_KEY=

# Optional Supabase business memory. The URL is not secret. The service-role key is
# secret and must stay server-side in this .env file; never expose it to the dashboard.
# When configured, real scout runs log reviewed and rejected leads for learning.
SUPABASE_URL=https://cakbzcvtqhdtxfjuxstd.supabase.co
SUPABASE_SERVICE_KEY=

# Keepa marketplace ("US" = amazon.com)
KEEPA_DOMAIN=US
# Hard wall-clock deadline (seconds) for any single Keepa wait=True call — a severely drained
# token bucket would otherwise block a scheduled run indefinitely (Code Review Finding S2).
KEEPA_CALL_DEADLINE_SECONDS=600

# ---- Deal Finder (optional, Deal Finder Build Plan Prompt D1) ----
# Best Buy Products API key (developer.bestbuy.com). Signups from free-email domains (Gmail)
# are rejected -- use a domain email. Absent -> the Best Buy connector honestly no-ops
# (Slickdeals RSS needs no key and runs either way).
BESTBUY_API_KEY=

# ---- File paths (optional) ----
DB_PATH=scout.db
MODEL_PATH=scout_model.joblib

# ---- Product-research criteria (optional overrides) ----
PRICE_MIN=15
PRICE_MAX=50
MIN_MONTHLY_SALES=200
MAX_REVIEWS=500
MAX_RATING=4.3
MAX_WEIGHT_LB=1.0
MAX_OFFERS=15

# ---- Pipeline behaviour (optional) ----
SCORE_THRESHOLD=70        # only send picks scoring >= this
TOP_N=5                   # max picks per run
CANDIDATE_LIMIT=200       # Product Finder result cap (Keepa allows up to 10000)

# ---- Margin-estimate ASSUMPTIONS (optional; tune to your reality) ----
REFERRAL_RATE=0.15        # most categories ~15%
FUEL_SURCHARGE=0.035      # 3.5% on fulfillment fees (2026)
COGS_FRACTION=0.30        # assumed landed cost as % of price
PPC_FRACTION=0.10         # assumed ad spend as % of price
TARGET_NET_MARGIN=0.25    # 25% net margin = healthy

# ---- Model blending (optional) ----
MODEL_BLEND_WEIGHT=0.5    # 0 = ignore model, 1 = trust only model
MIN_LABELS_TO_TRAIN=20    # need this many honest labels before training
